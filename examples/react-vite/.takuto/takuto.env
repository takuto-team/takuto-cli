# Secrets and environment variables sourced inside the container before
# authentication and startup. Only `export VAR=value` lines are honoured.
# Never put secrets in config.toml — keep them here.

# ── AI provider ──────────────────────────────────────────────────────────────
# Claude Code (skip interactive login):
# export ANTHROPIC_API_KEY="sk-ant-..."
# export CLAUDE_CODE_OAUTH_TOKEN="..."
# Custom Anthropic endpoint / proxy:
# export ANTHROPIC_BASE_URL="https://custom-proxy.example.com/claude"
#
# Cursor Agent (when [agent] provider = "cursor") — skips interactive login:
# export CURSOR_API_KEY="..."

# ── GitHub ─────────────────────────────────────────────────────────────────
# Fine-grained PAT scoped to the target repo (alternative to interactive gh login):
# export GH_TOKEN="github_pat_..."

# ── Integrations ─────────────────────────────────────────────────────────────
# export FIGMA_API_TOKEN=""

# ── External database (optional) ─────────────────────────────────────────────
# Overrides [database].connection. Leave unset for the local SQLite default.
# export TAKUTO_DATABASE_CONNECTION="postgres://takuto:pw@db.example:5432/takuto"

# License tier: community | cloud | enterprise (leave 'community' for self-hosted)
export TAKUTO_LICENSE_TIER=community
